# ── Provider selection ─────────────────────────────────────────────────────────
# Options: ollama | anthropic | openai | groq | together | claude-cli
LLM_PROVIDER=ollama

# ── Ollama (local, free) ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# Other good options: llama3.1:8b, deepseek-r1:14b, qwen2.5:7b

# ── If using a cloud provider, set the key here ────────────────────────────────
# (users can also bring their own key via the UI — it never touches the server)
LLM_API_KEY=

# ── Anthropic-specific ─────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI-compatible ──────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.groq.com/openai/v1   # uncomment for Groq

# ── Semantic Scholar (optional — raises rate limit) ────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
